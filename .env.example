# =============================================================================
# WILMS Monorepo — Environment Reference (root)
# Copy to `.env` for local development. Never commit `.env`.
# =============================================================================

# --- Frontend (Next.js) ---
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEMO_MODE=
NEXT_PUBLIC_FORCE_DEMO_MODE=
NEXT_PUBLIC_API_DISABLED=
NEXT_PUBLIC_USE_MOCK=
NEXT_PUBLIC_WILMS_ENV=development
NEXT_PUBLIC_APP_LOCK_IDLE_MS=300000

# BFF proxy upstream (Next.js /api/wilms → backend)
WILMS_API_UPSTREAM=http://127.0.0.1:4000

# --- Backend API ---
WILMS_API_PORT=4000
WILMS_API_HOST=127.0.0.1
API_PORT=4000
WILMS_CORS_ORIGIN=http://127.0.0.1:3000
WILMS_SESSION_SECRET=
WILMS_MIN_GROUP_SIZE=5
WILMS_MAX_GROUP_SIZE=15

# --- Database (Neon PostgreSQL) ---
# When unset, backend uses in-memory persistence.
DATABASE_URL=

# --- Uploads (backend only — see docs/engineering/cloudinary-setup.md) ---
UPLOAD_PROVIDER=local
WILMS_UPLOAD_DIR=.wilms-uploads
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
# Production: set UPLOAD_PROVIDER=cloudinary and fill credentials in deployment secrets
CLOUDINARY_CLOUD_NAME=daxaaq2zt
CLOUDINARY_API_KEY=752131924883685
CLOUDINARY_API_SECRET=u0M0YxcqcswK8asYJltIu0TseHM
CLOUDINARY_FOLDER=wilms

# --- Mail (infrastructure only — no workflows yet) ---
MAIL_PROVIDER=none
MAIL_FROM=noreply@wilms.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
RESEND_API_KEY=

# --- SMS (infrastructure only — no workflows yet) ---
SMS_PROVIDER=none
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- E2E / Playwright ---
FRONTEND_PORT=3000
PLAYWRIGHT_HOST=127.0.0.1
PLAYWRIGHT_PORT=3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_HOST=127.0.0.1
E2E_PORT=3000

# --- Runtime ---
NODE_ENV=development
CI=

# --- Production hardening (P14.5A) ---
# Set at deploy time for /health reporting
WILMS_GIT_COMMIT=
# Enable when behind reverse proxy (TLS termination)
WILMS_TRUST_PROXY=
WILMS_TRUST_PROXY_HOPS=1

# --- Financial certification thresholds (P14.5A.1) ---
# Override Neon-aware p95 budgets used by verify:financial (milliseconds)
# WILMS_VERIFY_SCHEDULE_P95_MS=2500
# WILMS_VERIFY_LOAN_LIST_P95_MS=750
