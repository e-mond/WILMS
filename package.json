{
  "name": "wilms",
  "version": "1.3.7",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @wilms/frontend",
    "dev:api": "npm run dev -w @wilms/api",
    "build": "npm run build -w @wilms/frontend",
    "start": "npm run start -w @wilms/frontend",
    "lint": "npm run lint -w @wilms/frontend",
    "type-check": "npm run type-check -w @wilms/frontend && npm run type-check -w @wilms/api",
    "type-check:api": "npm run type-check -w @wilms/api",
    "test": "npm run test -w @wilms/frontend",
    "test:coverage": "npm run test:coverage -w @wilms/frontend",
    "test:watch": "npm run test:watch -w @wilms/frontend",
    "test:e2e:install": "npm run test:e2e:install -w @wilms/frontend",
    "test:e2e": "npm run test:e2e -w @wilms/frontend",
    "smoke:production": "npm run smoke:production -w @wilms/api",
    "smoke:rbac": "npm run smoke:rbac -w @wilms/api",
    "smoke:staging": "npm run smoke:staging -w @wilms/api",
    "bundle:budget-check": "node scripts/bundle-budget-check.mjs",
    "perf:budget-check": "node scripts/perf-budget-check.mjs",
    "verify:version": "node scripts/verify-version-consistency.mjs",
    "verify:deploy-sync": "node scripts/verify-deploy-sync.mjs",
    "clean:local": "node scripts/clean-local.mjs",
    "seed:ghana-locations": "npm run seed:ghana-locations -w @wilms/api",
    "smoke:notifications": "npm run smoke:notifications -w @wilms/api",
    "verify:api-integrity": "node scripts/rc1-api-integrity.mjs",
    "verify:api-coverage": "node scripts/rc1-api-coverage.mjs",
    "verify:mock-guard": "node scripts/rc1-mock-import-guard.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "verify:empty-db": "npm run verify:empty-db -w @wilms/api"
  },
  "devDependencies": {
    "vitest": "3.2.6"
  }
}
