# Frontend — shared reference (see also .env.local.example / .env.production.example)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=
WILMS_API_UPSTREAM=http://127.0.0.1:4000
NEXT_PUBLIC_WILMS_ENV=development
NEXT_PUBLIC_APP_LOCK_IDLE_MS=300000

# Demo / mock toggles (unset = default mock in development)
NEXT_PUBLIC_DEMO_MODE=
NEXT_PUBLIC_FORCE_DEMO_MODE=
NEXT_PUBLIC_API_DISABLED=
NEXT_PUBLIC_USE_MOCK=

# E2E (used by playwright.config.ts)
FRONTEND_PORT=3000
PLAYWRIGHT_HOST=127.0.0.1
PLAYWRIGHT_PORT=3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_HOST=127.0.0.1
E2E_PORT=3000

# Gmail SMTP (Next.js server route /api/mail/gmail — optional; production mail runs on backend)
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
