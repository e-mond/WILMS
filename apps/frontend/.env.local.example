# Local development overrides — copy to `.env.local` (gitignored by Next.js)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api/wilms
WILMS_API_UPSTREAM=http://127.0.0.1:4000

# Cloudinary credentials are BACKEND ONLY — never add CLOUDINARY_API_SECRET here.
# Uploads are proxied through the API in production API mode.

# Long idle for E2E / manual testing
NEXT_PUBLIC_APP_LOCK_IDLE_MS=3600000

# E2E isolated port (avoids conflict with `npm run dev` on :3000)
PLAYWRIGHT_PORT=3001
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
E2E_PORT=3001
