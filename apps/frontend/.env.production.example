# Production frontend — set in deployment platform (Vercel, etc.)
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://app.wilms.example
NEXT_PUBLIC_API_BASE_URL=https://app.wilms.example/api/wilms
NEXT_PUBLIC_WILMS_ENV=production
WILMS_API_UPSTREAM=https://api.wilms.example

# Force live API (required: NODE_ENV=production + URL set)
NEXT_PUBLIC_DEMO_MODE=
NEXT_PUBLIC_API_DISABLED=
