# Production backend — set in deployment platform
NODE_ENV=production
WILMS_API_HOST=0.0.0.0
WILMS_API_PORT=4000
WILMS_CORS_ORIGIN=https://wilms.vercel.app
WILMS_SESSION_SECRET=
WILMS_TRUST_PROXY=true
WILMS_TRUST_PROXY_HOPS=1
WILMS_GIT_COMMIT=

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=wilms-prod

# Mail — pick one provider (Gmail recommended for test email in settings UI)
MAIL_PROVIDER=gmail
MAIL_FROM=noreply@wilms.example
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Alternative: MAIL_PROVIDER=resend + RESEND_API_KEY

# Gmail test/invite relay — Railway calls Vercel when SMTP is blocked outbound
WILMS_APP_URL=https://wilms.vercel.app
WILMS_VERCEL_MAIL_URL=https://wilms.vercel.app
WILMS_INTERNAL_MAIL_SECRET=

# SMS — SMSNotifyGH recommended for Ghana (matches settings UI)
SMS_PROVIDER=smsnotifygh
SMSNOTIFYGH_API_KEY=
SMSNOTIFYGH_SENDER_ID=
# Alternatives: SMS_PROVIDER=arkesel or twilio with matching credentials
