# Production backend — set in deployment platform
NODE_ENV=production
WILMS_API_HOST=0.0.0.0
WILMS_API_PORT=4000
WILMS_CORS_ORIGIN=https://app.wilms.example

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

