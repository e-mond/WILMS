# Local backend overrides — copy to `.env.local`
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

WILMS_CORS_ORIGIN=http://127.0.0.1:3000

# Optional: switch to Cloudinary when credentials are available
# See docs/engineering/cloudinary-setup.md
#UPLOAD_PROVIDER=local
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=wilms
