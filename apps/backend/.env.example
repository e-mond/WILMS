# Backend — shared reference (see also .env.local.example / .env.production.example)
WILMS_API_PORT=4000
WILMS_API_HOST=127.0.0.1
API_PORT=4000
WILMS_CORS_ORIGIN=http://127.0.0.1:3000
WILMS_UPLOAD_DIR=.wilms-uploads
WILMS_MIN_GROUP_SIZE=5
WILMS_MAX_GROUP_SIZE=15

DATABASE_URL=

UPLOAD_PROVIDER=cloudinary
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Production: UPLOAD_PROVIDER=cloudinary — see docs/engineering/cloudinary-setup.md
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=wilms


MAIL_PROVIDER=none
MAIL_FROM=noreply@wilms.local
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
RESEND_API_KEY=

SMS_PROVIDER=none
SMSNOTIFYGH_API_KEY=
SMSNOTIFYGH_SENDER_ID=
SMSNOTIFYGH_API_URL=https://sms.smsnotifygh.com/smsapi
SMSNOTIFYGH_BALANCE_URL=https://sms.smsnotifygh.com/api/balance/sms
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
