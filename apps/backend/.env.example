SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
RESEND_API_KEY=

SMS_PROVIDER=none
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=
TWILIO_ACCOUNT_SID=
